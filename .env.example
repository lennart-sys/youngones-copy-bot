# Slack — haal op via api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...        # OAuth Bot Token (onder "OAuth & Permissions")
SLACK_APP_TOKEN=xapp-...        # App-Level Token (onder "Basic Information" → App-Level Tokens, scope: connections:write)

# Anthropic — haal op via console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Pad naar de YoungOnes skill directory (optioneel — standaard: ../youngones-copywriter/skills/youngones-copywriter)
# Pas aan als de skill map ergens anders staat, of als je de bot op een server draait.
# YOUNGONES_SKILL_DIR=/pad/naar/youngones-copywriter/skills/youngones-copywriter
